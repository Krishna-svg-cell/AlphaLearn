# ============================================================
# ALPHALEARN Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL Database URL (REQUIRED)
# Get this from your cloud provider (Neon, Supabase, Railway, etc.)
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/alphalearn?sslmode=require
DATABASE_URL=

# JWT Secret for authentication tokens (REQUIRED - change in production!)
JWT_SECRET=alphalearn-secret-key-change-me

# Google Gemini API Key (optional, for AI dictionary lookups)
GOOGLE_API_KEY=

# Server Configuration
NODE_ENV=development
PORT=3000

# Connection Pool Settings (optional, defaults are good for most cases)
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT=30000
